# jetson_cam_bridge — configuration template
# Copy this file to .env and fill in your values.
# The bridge reads all settings from environment variables at startup.

# ── Camera ────────────────────────────────────────────────────────────────────
# Which camera driver to use.  Options: basler_pylon, aravis
CAMERA_PROVIDER=basler_pylon

# Camera serial number.  Leave empty to open the first available camera.
CAMERA_SERIAL=

# Resolution.  0 = sensor maximum.
CAMERA_WIDTH=0
CAMERA_HEIGHT=0

# Frame rate cap.  0 = camera's maximum.
CAMERA_FPS_LIMIT=60.0

# Pixel format.  Mono8 for monochrome, BayerRG8 / RGB8 for colour.
CAMERA_PIXEL_FORMAT=Mono8

# Exposure in microseconds.  0 = auto exposure.
CAMERA_EXPOSURE_US=0

# Analogue gain.  0 = auto gain.
CAMERA_GAIN=0

# GigE packet payload size.  Set to 8192 for jumbo frames.
# Requires: sudo ip link set eth0 mtu 9000  (see install.sh)
CAMERA_PACKET_SIZE=8192

# GigE inter-packet delay in nanoseconds.  0 = disabled.
# Increase if you see dropped packets on a busy network.
CAMERA_INTER_PACKET_DELAY_NS=0

# ── AI inference ──────────────────────────────────────────────────────────────
# Which AI task to run.  Options: passthrough (no model required), or your
# custom task name after adding it to inference/tasks/__init__.py.
TASK_CLASS=passthrough

# Path to a pre-built TensorRT .trt engine file.
# Leave empty to disable inference (passthrough only) or to auto-build from ONNX.
ENGINE_PATH=

# Path to an ONNX model.  If ENGINE_PATH does not exist, the bridge will call
# trtexec to build a .trt engine from this ONNX on first launch (takes minutes).
ONNX_PATH=

# Enable FP16 precision when building TRT engines.
# Recommended on Orin Nano — ~2x faster than FP32 with negligible accuracy loss.
INFERENCE_FP16=true

# Inference batch size.  Keep at 1 for real-time single-frame inference.
INFERENCE_BATCH_SIZE=1

# ── Bridge server ─────────────────────────────────────────────────────────────
# Address and port for the FastAPI server.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# JPEG quality for /stream and /snapshot endpoints (1-95).
# 85 is a good balance of image quality and network bandwidth.
STREAM_JPEG_QUALITY=85

# Ring buffer depth.  Higher values give the inference thread more slack to
# process frames without dropping, at the cost of RAM.  8 is a safe default.
RING_BUFFER_CAPACITY=8

# ── Radian Forge integration (optional) ───────────────────────────────────────
# If set, the bridge will push inference results to Radian Forge via HTTP.
# Leave empty to disable.
RADIAN_FORGE_URL=

# Push interval in seconds.  0 = push every frame over WebSocket only.
PUSH_INTERVAL_S=0
